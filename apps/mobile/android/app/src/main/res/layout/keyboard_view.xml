<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F1F1F1"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/brandText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="HyperVoice"
            android:textColor="#080808"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="32dp"
            android:background="@drawable/ime_toggle_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="2dp">

            <Button
                android:id="@+id/voiceToggleButton"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:background="@drawable/ime_toggle_active"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="🎤"
                android:textAllCaps="false"
                android:textColor="#080808"
                android:textSize="13sp" />

            <Button
                android:id="@+id/languageToggleButton"
                android:layout_width="0dp"
                android:layout_height="28dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="EN"
                android:textAllCaps="false"
                android:textColor="#080808"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:gravity="center"
        android:text="Tap to speak"
        android:textColor="#666666"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/previewText"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/ime_preview_bg"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="#111111"
        android:textSize="14sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/voicePanel"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center">

            <ImageButton
                android:id="@+id/micButton"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_gravity="center"
                android:background="@drawable/ime_mic_button_circle"
                android:contentDescription="Mic"
                android:padding="14dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_mic" />

            <LinearLayout
                android:id="@+id/waveContainer"
                android:layout_width="96dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <View
                    android:id="@+id/waveBar1"
                    android:layout_width="6dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/ime_wave_bar" />

                <View
                    android:id="@+id/waveBar2"
                    android:layout_width="6dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/ime_wave_bar" />

                <View
                    android:id="@+id/waveBar3"
                    android:layout_width="6dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/ime_wave_bar" />

                <View
                    android:id="@+id/waveBar4"
                    android:layout_width="6dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/ime_wave_bar" />

                <View
                    android:id="@+id/waveBar5"
                    android:layout_width="6dp"
                    android:layout_height="40dp"
                    android:layout_margin="3dp"
                    android:background="@drawable/ime_wave_bar" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/returnButton"
                android:layout_width="130dp"
                android:layout_height="42dp"
                android:background="@drawable/ime_key_bg"
                android:text="return"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="15sp" />

            <Button
                android:id="@+id/voiceBackspaceButton"
                android:layout_width="62dp"
                android:layout_height="42dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/ime_key_bg"
                android:text="⌫"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="17sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/keyboardPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/keyboardRows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>

    <Button
        android:id="@+id/hideKeyboardButton"
        android:layout_width="64dp"
        android:layout_height="28dp"
        android:layout_marginTop="6dp"
        android:background="@android:color/transparent"
        android:text="▼"
        android:textAllCaps="false"
        android:textColor="#222222"
        android:textSize="20sp" />
</LinearLayout>
