<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F8F9FF"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="4dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="44dp" android:gravity="center_vertical" android:orientation="horizontal">
        <TextView android:id="@+id/brandText" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_vertical" android:text="HyperVoice" android:textColor="#050713" android:textSize="24sp" android:textStyle="bold" />
        <LinearLayout android:layout_width="164dp" android:layout_height="42dp" android:background="@drawable/ime_toggle_bg" android:gravity="center" android:orientation="horizontal" android:padding="3dp">
            <Button android:id="@+id/voiceToggleButton" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:background="@drawable/ime_toggle_active" android:minWidth="0dp" android:padding="0dp" android:text="Mic" android:textAllCaps="false" android:textColor="#111827" android:textSize="16sp" android:textStyle="bold" />
            <Button android:id="@+id/languageToggleButton" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:background="@android:color/transparent" android:minWidth="0dp" android:padding="0dp" android:text="EN" android:textAllCaps="false" android:textColor="#111827" android:textSize="18sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/statusText" android:layout_width="match_parent" android:layout_height="28dp" android:gravity="center" android:text="Tap to speak" android:textColor="#777CA0" android:textSize="16sp" />
    <TextView android:id="@+id/previewText" android:layout_width="match_parent" android:layout_height="38dp" android:layout_marginBottom="4dp" android:background="@drawable/ime_preview_bg" android:gravity="center_vertical" android:paddingStart="12dp" android:paddingEnd="12dp" android:textColor="#111827" android:textSize="15sp" android:visibility="gone" />

    <LinearLayout android:id="@+id/voicePanel" android:layout_width="match_parent" android:layout_height="214dp" android:gravity="center" android:orientation="vertical" android:visibility="gone">
        <FrameLayout android:layout_width="260dp" android:layout_height="104dp" android:layout_gravity="center">
            <LinearLayout android:id="@+id/waveContainer" android:layout_width="240dp" android:layout_height="78dp" android:layout_gravity="center" android:gravity="center" android:orientation="horizontal" android:visibility="gone">
                <View android:id="@+id/waveBar1" android:layout_width="6dp" android:layout_height="34dp" android:layout_margin="4dp" android:background="@drawable/ime_wave_bar" />
                <View android:id="@+id/waveBar2" android:layout_width="6dp" android:layout_height="50dp" android:layout_margin="4dp" android:background="@drawable/ime_wave_bar" />
                <View android:id="@+id/waveBar3" android:layout_width="7dp" android:layout_height="70dp" android:layout_margin="4dp" android:background="@drawable/ime_wave_bar" />
                <View android:id="@+id/waveBar4" android:layout_width="6dp" android:layout_height="50dp" android:layout_margin="4dp" android:background="@drawable/ime_wave_bar" />
                <View android:id="@+id/waveBar5" android:layout_width="6dp" android:layout_height="34dp" android:layout_margin="4dp" android:background="@drawable/ime_wave_bar" />
            </LinearLayout>
            <ImageButton android:id="@+id/micButton" android:layout_width="86dp" android:layout_height="86dp" android:layout_gravity="center" android:background="@drawable/ime_mic_button_circle" android:contentDescription="Mic" android:padding="19dp" android:scaleType="fitCenter" android:src="@drawable/ic_mic" />
        </FrameLayout>
        <TextView android:layout_width="match_parent" android:layout_height="26dp" android:gravity="center" android:text="Listening..." android:textColor="#777CA0" android:textSize="16sp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="8dp" android:gravity="center" android:orientation="horizontal">
            <Button android:id="@+id/returnButton" android:layout_width="172dp" android:layout_height="52dp" android:background="@drawable/ime_key_bg" android:text="Return" android:textAllCaps="false" android:textColor="#111827" android:textSize="21sp" android:textStyle="bold" />
            <Button android:id="@+id/voiceBackspaceButton" android:layout_width="74dp" android:layout_height="52dp" android:layout_marginStart="14dp" android:background="@drawable/ime_key_bg" android:text="Del" android:textAllCaps="false" android:textColor="#4F46E5" android:textSize="20sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/keyboardPanel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <LinearLayout android:id="@+id/keyboardRows" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
    </LinearLayout>

    <Button android:id="@+id/hideKeyboardButton" android:layout_width="64dp" android:layout_height="24dp" android:layout_marginTop="2dp" android:background="@android:color/transparent" android:text="v" android:textAllCaps="false" android:textColor="#7A809A" android:textSize="20sp" />
</LinearLayout>
